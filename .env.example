# Copy to .env and fill in. NEVER commit .env. (.env is gitignored.)
# THIS FILE IS A TEMPLATE — DO NOT PUT REAL SECRETS HERE. Use placeholders only.

# --- runtime ---
ENV=dev
LOG_LEVEL=INFO
LOG_JSON=false
CONFIG_DIR=config

# --- PostgreSQL / TimescaleDB ---
# In docker-compose, POSTGRES_HOST is overridden to the service name (timescaledb).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ats
POSTGRES_USER=ats
POSTGRES_PASSWORD=change-me        # NOT 'ats' in prod. Prefer alphanumeric (DSN-safe).
# Host interface the DB port publishes on. Default 127.0.0.1 keeps the DB off the
# public internet even if a security group is misconfigured. Don't change in prod.
DB_BIND_ADDR=127.0.0.1
# POSTGRES_HOST_PORT=5544           # host-side port (container is always 5432)

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Opt-in Redis auth. Empty => no password (dev). Set a strong value in prod; it is
# wired into the app's redis_url automatically. NOTE: if you front AWS Redis via the
# local SSH tunnel (docker-compose.override.yml), set the SAME value in the local .env.
REDIS_PASSWORD=
REDIS_BIND_ADDR=127.0.0.1          # host interface the Redis port publishes on
# REDIS_HOST_PORT=6399             # host-side port (container is always 6379)

# --- Zerodha Kite Connect ---
KITE_API_KEY=
KITE_API_SECRET=
KITE_USER_ID=
KITE_PASSWORD=
KITE_TOTP_SECRET=
KITE_REDIRECT_URL=https://127.0.0.1

# --- secure token storage ---
TOKEN_STORE_PATH=.secrets/kite_token.json
# Generate a Fernet key:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# STRONGLY RECOMMENDED in any non-throwaway environment. Empty => plaintext (DEV ONLY).
TOKEN_ENCRYPTION_KEY=

# --- API control-plane auth ---
# When set, all /api/* routes and the /ws stream require Authorization: Bearer <token>.
# Leave empty ONLY on a trusted, localhost-bound dev box.
API_AUTH_TOKEN=
# Optional scoped tokens (opt-in). Each grants its level and below
# (read < operator < trader < admin). If only API_AUTH_TOKEN is set it acts as
# admin, so the single-token dashboard keeps working. Generate strong values:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN_READONLY=
API_TOKEN_OPERATOR=
API_TOKEN_TRADER=
API_TOKEN_ADMIN=
# Comma-separated allowed CORS origins. "*" = any (dev). Set to the dashboard origin in prod.
CORS_ALLOW_ORIGINS=*

# --- SMTP alerts ---
# Daily EOD equity report + operator alerts are emailed here. Any SMTP relay works
# (e.g. Brevo: SMTP_HOST=smtp-relay.brevo.com, PORT=587, USER=<login>@smtp-brevo.com).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=                 # verified sender address (e.g. admin@yourdomain)
SMTP_FROM_NAME=            # display name in the From header (optional, e.g. OutFyld)
SMTP_USE_TLS=true          # STARTTLS on 587 (set per your relay)
ALERT_EMAIL_TO=            # recipient for reports/alerts

# --- LLM (Phase 5) ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
